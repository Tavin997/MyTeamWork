# ============================================
# MyTeamWork - Environment Configuration
# ============================================

# Database Configuration (AIVEN)
DB_HOST=myteamwork-db.aivencloud.com
DB_PORT=12345
DB_NAME=myteamwork
DB_USER=avnadmin
DB_PASS=your_secure_password_here
DB_DRIVER=mysql

# AIVEN SSL Configuration
DB_SSL_CA=/path/to/ca.pem
DB_SSL_CERT=/path/to/cert.pem
DB_SSL_KEY=/path/to/key.pem

# Application Settings
APP_ENV=production
APP_DEBUG=false
APP_URL=https://myteamwork.com

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRY=3600

# CORS Settings
CORS_ALLOWED_ORIGINS=https://myteamwork.com,https://app.myteamwork.com