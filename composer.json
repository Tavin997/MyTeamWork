{
    "name": "myteamwork/api",
    "description": "MyTeamWork RESTful API",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "ext-pdo": "*",
        "ext-pdo_mysql": "*",
        "ext-json": "*",
        "ext-openssl": "*",
        "firebase/php-jwt": "^6.4",
        "vlucas/phpdotenv": "^5.5",
        "monolog/monolog": "^3.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "MyTeamWork\\": "api/"
        }
    },
    "scripts": {
        "migrate": "php api/migrations/migrate.php",
        "migrate:rollback": "php api/migrations/migrate.php --rollback"
    }
}